      </column>
      <column caption='Shot Result' datatype='string' datatype-customized='true' name='[Calculation_0996988758196230]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SHOT_MADE_FLAG] = 1 THEN &quot;Made&quot; ELSE &quot;Missed&quot; END' />
      </column>
      <column caption='Zone' datatype='string' name='[Calculation_0996988758237191]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SHOT_ZONE_BASIC] = &quot;Restricted Area&quot; THEN &quot;Restricted Area&quot; ELSEIF [SHOT_ZONE_BASIC] = &quot;In The Paint (Non-RA)&quot; THEN &quot;In The Paint&quot; ELSEIF [SHOT_ZONE_BASIC] = &quot;Mid-Range&quot; THEN &quot;Mid-Range&quot; ELSEIF [SHOT_ZONE_BASIC] IN (&quot;Left Corner 3&quot;, &quot;Right Corner 3&quot;) THEN &quot;Corner 3&quot; ELSEIF [SHOT_ZONE_BASIC] = &quot;Above the Break 3&quot; THEN &quot;Above Brk 3&quot; ELSE [SHOT_ZONE_BASIC] END' />
      </column>
      <column caption='Team Abbrev' datatype='string' name='[Calculation_0996988758302728]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [TEAM_NAME] = &quot;Oklahoma City Thunder&quot; THEN &quot;OKC&quot; ELSEIF [TEAM_NAME] = &quot;Indiana Pacers&quot; THEN &quot;IND&quot; ELSE &quot;N/A&quot; END' />
      </column>
      <column caption='FG%' datatype='real' name='[Calculation_0996988758351881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SHOT_MADE_FLAG]) / COUNT([GAME_ID]) * 100' />
      </column>
      <column caption='Is Selected Game' datatype='boolean' name='[Calculation_0996988760428554]' role='dimension' type='nominal'>
