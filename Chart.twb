      <column caption='Action Type' datatype='string' name='[ACTION_TYPE]' role='dimension' type='nominal' />
      <column caption='Header - Winner Name' datatype='string' name='[Calculation_0169881050701824]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_0996988757651456]) &gt; SUM([Calculation_0996988757716993]) THEN &quot;OKC ✔&quot; ELSE &quot;IND ✔&quot; END' />
      </column>
      <column caption='Header - Score Text' datatype='string' name='[Calculation_0169881050816513]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(MAX(SUM([Calculation_0996988757651456]), SUM([Calculation_0996988757716993]))) + &quot;-&quot; + STR(MIN(SUM([Calculation_0996988757651456]), SUM([Calculation_0996988757716993])))' />
      </column>
      <column caption='Coordinate X (Events)' datatype='real' name='[Calculation_0793305142562819]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[loc_x]/10' />
