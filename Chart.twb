                <alias key='&quot;42400407&quot;' value='Game 7' />
              </aliases>
            </column>
            <column caption='Shot Made Flag' datatype='integer' name='[SHOT_MADE_FLAG]' role='dimension' type='ordinal' />
            <column caption='Shot Zone Basic' datatype='string' name='[SHOT_ZONE_BASIC]' role='dimension' type='nominal' />
            <column caption='Team Name' datatype='string' name='[TEAM_NAME]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0996988758237191]' derivation='None' name='[none:Calculation_0996988758237191:nk]' pivot='key' type='nominal' />
