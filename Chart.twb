                <alias key='&quot;42400406&quot;' value='G6' />
                <alias key='&quot;42400407&quot;' value='G7' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0lz1l050mfhw5r16ei54f0t0roiq'>
            <column caption='IF [OKC is Leading] THEN &quot;OKC&quot; ELSE &quot;IND&quot; END' datatype='string' name='[Calculation_0793305098244098]' role='measure' type='nominal' user:unnamed='Worm Chart - Lead/Deficit'>
              <calculation class='tableau' formula='IF [Calculation_0996988757880835] THEN &quot;OKC&quot; ELSE &quot;IND&quot; END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='OKC Points' datatype='integer' name='[Calculation_0996988757651456]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [team_name] = &apos;Oklahoma City Thunder&apos; THEN [points] ELSE 0 END' />
            </column>
            <column caption='IND Points' datatype='integer' name='[Calculation_0996988757716993]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [team_name] = &apos;Indiana Pacers&apos; THEN [points] ELSE 0 END' />
            </column>
            <column caption='OKC Lead Margin' datatype='integer' name='[Calculation_0996988757782530]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RUNNING_SUM(SUM([Calculation_0996988757651456])) - RUNNING_SUM(SUM([Calculation_0996988757716993]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='OKC is Leading' datatype='boolean' name='[Calculation_0996988757880835]' role='measure' type='nominal'>
              <calculation class='tableau' formula='[Calculation_0996988757782530] &gt; 0'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Is Selected Game' datatype='boolean' name='[Calculation_0996988760428554]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Game Id Parameter] = &apos;0&apos; OR [GAME_ID] = [Parameters].[Game Id Parameter]' />
            </column>
            <column caption='Game Id' datatype='string' datatype-customized='true' name='[GAME_ID]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;42400401&quot;' value='Game 1' />
                <alias key='&quot;42400402&quot;' value='Game 2' />
                <alias key='&quot;42400403&quot;' value='Game 3' />
                <alias key='&quot;42400404&quot;' value='Game 4' />
                <alias key='&quot;42400405&quot;' value='Game 5' />
                <alias key='&quot;42400406&quot;' value='Game 6' />
                <alias key='&quot;42400407&quot;' value='Game 7' />
              </aliases>
            </column>
            <column caption='Min Elapsed' datatype='real' name='[min_elapsed]' role='measure' type='quantitative' />
