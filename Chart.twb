      <column caption='Coordinate Y (Events)' datatype='real' name='[Calculation_0793305142644740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[loc_y]/10' />
      </column>
      <column caption='dzv.Show_Momentum' datatype='boolean' name='[Calculation_0793305158131717]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1]=&apos;Momentum&apos;' />
      </column>
      <column caption='OKC Points' datatype='integer' name='[Calculation_0996988757651456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [team_name] = &apos;Oklahoma City Thunder&apos; THEN [points] ELSE 0 END' />
      </column>
      <column caption='IND Points' datatype='integer' name='[Calculation_0996988757716993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [team_name] = &apos;Indiana Pacers&apos; THEN [points] ELSE 0 END' />
      </column>
      <column caption='OKC Lead Margin' datatype='integer' name='[Calculation_0996988757782530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Calculation_0996988757651456])) - RUNNING_SUM(SUM([Calculation_0996988757716993]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='OKC is Leading' datatype='boolean' name='[Calculation_0996988757880835]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0996988757782530] &gt; 0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Coordinate X' datatype='real' name='[Calculation_0996988758065156]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[LOC_X] / 10' />
      </column>
      <column caption='Coordinate Y' datatype='real' name='[Calculation_0996988758106117]' role='measure' type='quantitative'>
